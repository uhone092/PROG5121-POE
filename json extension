{
  "LoginTest": {
    "package": "com.mycompany.login",
    "imports": [
      "org.junit.Before",
      "org.junit.After",
      "org.junit.Test",
      "org.junit.Assert"
    ],
    "testData": {
      "message1": {
        "recipient": "+27718693002",
        "content": "Hi Mike, can you join us for dinner tonight"
      },
      "message2": {
        "recipient": "08575975889",
        "content": "Hi keegan, did you receive the payment?"
      }
    },
    "helperMethods": [
      "validateMessageLength",
      "validateRecipientCell",
      "processMessageAction"
    ],
    "testCategories": {
      "constructorTests": [
        "testMessageConstructor_ValidInputs",
        "testMessageConstructor_EmptyMessage",
        "testMessageConstructor_EmptyRecipient",
        "testMessageConstructor_NullValues"
      ],
      "getterTests": [
        "testGetRecipient",
        "testGetMessageContent",
        "testGetMessageID",
        "testGetMessageHash"
      ],
      "validationTests": [
        "testMessageLengthValidation_Success",
        "testMessageLengthValidation_Failure",
        "testMessageLengthValidation_ExactLimit",
        "testRecipientValidation_Success",
        "testRecipientValidation_Failure",
        "testRecipientValidation_EdgeCases"
      ],
      "hashTests": [
        "testMessageHashCorrectness",
        "testMessageHashSingleWord"
      ],
      "idTests": [
        "testMessageIDCreation",
        "testMessageIDUniqueness"
      ],
      "actionTests": [
        "testMessageAction_Send",
        "testMessageAction_Disregard",
        "testMessageAction_Store",
        "testMessageAction_Invalid"
      ],
      "totalMessageTests": [
        "testTotalMessagesSent",
        "testTotalMessagesReset"
      ],
      "completeFlowTests": [
        "testCompleteMessageFlow_Message1",
        "testCompleteMessageFlow_Message2"
      ],
      "edgeCaseTests": [
        "testSpecialCharacters",
        "testMessageWithNewLines",
        "testMultipleMessages",
        "testStaticMethodsIndependence"
      ]
    }
  }
}
